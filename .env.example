# =============================================================================
# Environment Variables — copy to .env and fill in real values
# =============================================================================

# --- PostgreSQL (for local Docker dev) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crowdcheck

# --- .NET API ---
# Neon connection string for production (requires SslMode=Require):
# Host=ep-xxx.us-east-2.aws.neon.tech;Port=5432;Database=crowdcheck;Username=crowdcheck_owner;Password=xxx;SslMode=Require
CONNECTION_STRING=Host=db;Port=5432;Database=crowdcheck;Username=postgres;Password=change-me

# Your Cloudflare Pages URL (e.g. https://crowdcheck.pages.dev)
FRONTEND_ORIGIN=https://your-frontend-domain.com

# Random secret for IP hashing — generate with: openssl rand -hex 32
IP_HASH_SECRET=change-this-to-a-random-64-char-hex-string
